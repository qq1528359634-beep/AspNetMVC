<!--定义模型类型-->
@model IEnumerable<SelfAspNet_MVC.Models.Book>
@{
    ViewData["Title"] = "List";
}
<table class="table">
    <thead>
        <tr>
            <th>ISBN code</th>
            <th>書名</th>
            <th>価格</th>
            <th>出版社</th>
            <th>発行日</th>
            <th>配布サンプル</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Isbn</td>
                <td>@item.Title</td>
                <td>@item.Price</td>
                <td>@item.Publisher</td>
                <td>@item.Published</td>
                <td>@item.Sample</td>
            </tr>


        }
    </tbody>
</table>

